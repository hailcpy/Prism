# ── Provider keys (supply at least one) ──────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Infrastructure (wired by Docker Compose; change only for local overrides) ─
DATABASE_URL=postgres://olive:olive@postgres:5432/olive
REDIS_URL=redis://redis:6379/0
INGESTION_URL=http://ingestion-api:8001

# ── Olive tunables ────────────────────────────────────────────────────────────
# If true, ingestion redacts and persists the full raw_payload (debug only).
# Logs a loud warning at startup. Keep false in production.
OLIVE_KEEP_RAW=false
OLIVE_LOG_LEVEL=INFO

# ── Partition retention ───────────────────────────────────────────────────────
PARTITION_RETENTION_DAYS=30

# ── Credential encryption ────────────────────────────────────────────────────
# Required after Phase 9 for DB-backed provider credentials.
# Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
PRISM_CREDS_KEY=

# ── Provider keys (legacy/dev fallback before Phase 9 cutover) ───────────────
# After Phase 9, add provider credentials in the Settings UI instead of storing
# them in browser localStorage or sending them as x-prism-* request headers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=us-west-2

# ── Infrastructure (wired by Docker Compose; change only for local overrides) ─
# Postgres creds — change in production; defaults are fine for local dev.
# NOTE: changing POSTGRES_PASSWORD after the volume is initialized will NOT
# update the existing role's password. Either run `make nuke` to start fresh,
# or `ALTER USER` inside psql first.
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism
POSTGRES_DB=prism
POSTGRES_PORT=5433

# Redis — REQUIRED. Compose refuses to start without it (no anonymous Redis).
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
REDIS_PASSWORD=
REDIS_PORT=6379

# Composed URLs — keep host/db parts matching the variables above.
# The compose file builds these itself for the containers; this file is for
# anything you run from the host (CLI scripts, etc.).
DATABASE_URL=postgres://prism:prism@localhost:5433/prism
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
INGESTION_URL=http://ingestion-api:8001

# ── Prism tunables ────────────────────────────────────────────────────────────
# If true, ingestion redacts and persists the full raw_payload (debug only).
# Logs a loud warning at startup. Keep false in production.
PRISM_KEEP_RAW=false
# PII redactor implementation: `regex` (default, zero deps) or `presidio`
# (requires the `presidio` extra: `uv pip install 'ingestion-api[presidio]'`).
PRISM_REDACTOR=regex
PRISM_LOG_LEVEL=INFO

# ── Partition retention ───────────────────────────────────────────────────────
PARTITION_RETENTION_DAYS=30
